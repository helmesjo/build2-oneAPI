      ],
      "depends": []
    },
    "tbb-bind": {
      "libs": [
        "tbb-runtime/bin/tbbbind.dll",
        "tbb-runtime/bin/tbbbind_2_0.dll",
        "tbb-runtime/bin/tbbbind_2_5.dll"],
      "libi": [
        "tbb-devel/lib/tbbbind.lib",
        "tbb-devel/lib/tbbbind_2_0.lib",
        "tbb-devel/lib/tbbbind_2_5.lib"],
      "depends": []
