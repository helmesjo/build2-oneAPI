import tbb             = liboneapi-tbb%libs{tbb}
import tbb_malloc       = liboneapi-tbb%libs{tbb-malloc}
import tbb_malloc_proxy = liboneapi-tbb%libs{tbb-malloc-proxy}
import tbb_bind         = liboneapi-tbb%libs{tbb-bind}

# tbb/tbb-bind: C++ API headers call internal DLL symbols.
#         NOTE: On Windows only MSVC is supported due to C++ name mangling.
#
./: exe{test-tbb}: \
  include = ($cc.target.class != 'windows' || $cxx.target.system == 'win32-msvc')
exe{test-tbb}: cxx{tbb} $tbb

./: exe{test-tbb-malloc}:       cxx{tbb-malloc}       $tbb $tbb_malloc
./: exe{test-tbb-malloc-proxy}: cxx{tbb-malloc-proxy} $tbb $tbb_malloc_proxy
./: exe{test-tbb-bind}: \
  include = ($cc.target.class != 'windows' || $cxx.target.system == 'win32-msvc')
exe{test-tbb-bind}: cxx{tbb-bind} $tbb $tbb_bind
